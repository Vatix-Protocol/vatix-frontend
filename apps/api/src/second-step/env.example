# ── Auth / JWT ────────────────────────────────────────────────────────────────

# Secret used to sign and verify JWTs.  Must be at least 32 chars in production.
JWT_SECRET=change-me-to-a-long-random-string

# How long issued JWTs are valid.  Uses the ms / zeit/ms format accepted by
# jsonwebtoken: '15m', '1h', '7d', etc.
# Defaults to '15m' if not set.
JWT_EXPIRES_IN=15m

# ── Redis ─────────────────────────────────────────────────────────────────────

REDIS_HOST=localhost
REDIS_PORT=6379

# Leave blank for unauthenticated local Redis:
REDIS_PASSWORD=

# Set to 'true' when using TLS-terminated Redis (e.g. Railway):
REDIS_TLS=false
