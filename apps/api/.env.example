# Database (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swyft

# Redis (BullMQ + Cache)
REDIS_URL=redis://localhost:6379

# Stellar
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
POOL_CONTRACT_ID=

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# App
PORT=3001

# Internal API key — protects /admin/* and /metrics/db
INTERNAL_API_KEY=change-me-in-production

# DB query monitoring (#73)
DB_SLOW_QUERY_THRESHOLD_MS=100

# Sentry (#85) — leave blank to disable Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Compression (#84) — zlib level 1-9, default 6
COMPRESSION_LEVEL=6
