# Database (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swyft

# Redis (BullMQ + Cache)
REDIS_URL=redis://localhost:6379

# Stellar
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
POOL_CONTRACT_ID=

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# App
PORT=3001

# Backup (Issue #3)
BACKUP_S3_BUCKET=swyft-backups
BACKUP_S3_ENDPOINT=        # optional: set for Cloudflare R2 or MinIO
BACKUP_RETAIN_DAYS=30
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1